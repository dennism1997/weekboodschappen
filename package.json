{
  "name": "weekboodschappen",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @weekboodschappen/server dev & pnpm --filter @weekboodschappen/client dev",
    "build": "pnpm --filter @weekboodschappen/server build && pnpm --filter @weekboodschappen/client build",
    "dev:server": "pnpm --filter @weekboodschappen/server dev",
    "dev:client": "pnpm --filter @weekboodschappen/client dev",
    "db:reset": "pnpm --filter @weekboodschappen/server db:reset"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
