{
  "name": "@weekboodschappen/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outdir=dist --packages=external",
    "start": "node --env-file=.env dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts",
    "db:reset": "rm -f ${DATABASE_PATH:-./data/weekboodschappen.db} ${DATABASE_PATH:-./data/weekboodschappen.db}-wal ${DATABASE_PATH:-./data/weekboodschappen.db}-shm",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@better-auth/passkey": "^1.5.6",
    "@posthog/ai": "^7.12.8",
    "@simplewebauthn/server": "^13.3.0",
    "albert-heijn-wrapper": "^3.0.0",
    "better-auth": "^1.5.6",
    "better-sqlite3": "^12.8.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jumbo-wrapper": "^2.1.0",
    "node-cron": "^4.2.1",
    "playwright": "^1.58.2",
    "posthog-node": "^5.28.11",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.27.4",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
